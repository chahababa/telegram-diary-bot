# ── Telegram Bot ───────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ── OpenAI ─────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here

# ── Google Drive ────────────────────────────────────
GOOGLE_DRIVE_FOLDER_ID=your_google_drive_folder_id_here
# 雲端部署時貼入 Service Account JSON 金鑰的完整內容
GOOGLE_CREDENTIALS_JSON=

# ── Google Calendar ─────────────────────────────────
# 要讀取的 Google Calendar ID（通常是 Gmail 信箱）
GCAL_CALENDAR_ID=

# ── Notion 同步 ─────────────────────────────────────
# Notion Integration Token（在 https://www.notion.so/my-integrations 建立）
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 日記資料庫的 Notion Database ID（從資料庫頁面 URL 取得）
NOTION_DIARY_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── 其他設定 ────────────────────────────────────────
TIMEZONE=Asia/Taipei
DATABASE_PATH=diary.db
GPT_MODEL=gpt-4o
LOCAL_BACKUP_DIR=backup_diaries
